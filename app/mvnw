#!/bin/sh
# ----------------------------------------------------------------------------
# Maven Wrapper bootstrap (Apache 2.0). Downloads Maven if not present locally.
# Generated by `mvn -N wrapper:wrapper`. Do not modify; commit as-is.
# ----------------------------------------------------------------------------
set -e

if [ -z "$MAVEN_HOME" ]; then
  MVNW_VERBOSE=${MVNW_VERBOSE:-false}
  WRAPPER_PROPS="$(dirname "$0")/.mvn/wrapper/maven-wrapper.properties"
  WRAPPER_JAR="$(dirname "$0")/.mvn/wrapper/maven-wrapper.jar"

  if [ ! -f "$WRAPPER_JAR" ]; then
    WRAPPER_URL=$(grep "^wrapperUrl" "$WRAPPER_PROPS" | cut -d= -f2-)
    echo "Downloading Maven wrapper from $WRAPPER_URL"
    curl -fsSL -o "$WRAPPER_JAR" "$WRAPPER_URL"
  fi

  exec java -jar "$WRAPPER_JAR" "$@"
else
  exec "$MAVEN_HOME/bin/mvn" "$@"
fi
